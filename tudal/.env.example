# tudal/.env.example — 주픽(JooPick) 환경변수 템플릿
# 실제 값은 tudal/.env.local에 입력 (gitignore됨). 여기는 키 이름·placeholder만.
# 최초 작성: 2026-04-21 (S7·S8 착수 준비)

# ──────────────────────────────────────────────────────────────
# [S0 Foundation] Supabase — 어드민 인증·DB·RLS
# 프로젝트: rbrpcynhphrpljbjirfo
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Supabase Dashboard → Settings → API → "anon public" JWT 복사 (legacy 포맷)
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_JWT_HERE

# Magic Link redirect base URL. Production/preview must use the deployed host.
NEXT_PUBLIC_SITE_URL=https://your-deployment.example.com

# (선택) 새 Supabase publishable key (sb_publishable_...) — 참고 보관용
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx

# 서버 전용 — NEXT_PUBLIC_ prefix 절대 금지
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_JWT_HERE

# 어드민 allowlist (comma-separated, BL-2 해소 방식)
# middleware.ts에서 /admin/* 가드에 사용
ADMIN_EMAILS=admin1@example.com,admin2@example.com,admin3@example.com

# ──────────────────────────────────────────────────────────────
# [S7a] Anthropic — 리포트·브리핑·뉴스 분류·AI 어댑터
# BL-KRIT-1 선행
# ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# W0 (65차 Q3/D28): GPT = 선택 secondary (Claude 필수 primary — GPT-only 미지원).
# 미설정 시 GPT 역할(critic 등) 자동 Claude fallback (auto-detect).
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
AI_COST_LOG_REAL_INSERT_ENABLED=false   # Q2 cost_log DB INSERT toggle (default off)
AI_PROMPT_CACHE_ENABLED=false           # Q6 Anthropic prompt caching toggle (default off)
PR4_TRIGGER_UPSERT_ENABLED=false        # B65-P3 옵션 A admin-only UPSERT (마이그 0025) 활성화. default=false (safe local/preview — 마이그 0025 미적용 시 admin trigger crash 회피). Production Vercel env에서만 USER가 true 설정 (B98 lock-in)
PR5_CRON_AUTO_ENABLED=false             # PR5 monthly report-worker 자동 생성 toggle. default=false; prod USER 승인 후 true.
PR5_CRON_SELF_CONTINUE=false            # PR5 optional after() self-continue accelerator. daily cron이 primary이므로 기본 false.
MONTHLY_BATCH_CRON_AI_ENABLED=false     # PR-G cron monthly-batch(단발 경로) 실 Core 11 AI 30선정 자동 가동 toggle. default=false (merge-safe — cron preflight가 실 Anthropic 전 차단 → cost 0). prod USER 비용 승인 + 150 시드 + CRON_SYSTEM_USER_ID seed 후 true.
SELECTION_CRON_AUTO_ENABLED=false        # Tier1 selection chunk worker(청크 경로) 자동 30선정 toggle. default=false (merge-safe — route 200 skip + worker step-0 abort → claim 0, LLM 0, spend 0). 단발 MONTHLY_BATCH_CRON_AI_ENABLED와 동시 on 금지(같은 month cost 중복 — 데이터는 전용 run-mutex로 안전). prod USER 비용 승인 후 true.
SELECTION_CRON_SELF_CONTINUE=false       # Tier1 selection worker optional after() self-continue accelerator. daily cron이 primary이므로 기본 false.
# cost_log.called_by FK용 reserved auth.users UUID (PR5 report-worker + PR-G monthly-batch 공용). Supabase Auth에 cron-system user를 1회 seed한 뒤 해당 UUID를 입력.
CRON_SYSTEM_USER_ID=00000000-0000-4000-8000-000000000000

# ──────────────────────────────────────────────────────────────
# [S7b] Naver News — M12 뉴스 sweep
# BL-KRIT-3 선행. Naver Developers 앱 등록 후 발급
# ──────────────────────────────────────────────────────────────
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ──────────────────────────────────────────────────────────────
# [S7b·c·d] Resend — M11 모닝 브리핑 · D10 이메일 재시도 · M19 Silent Health
# BL-KRIT-4 선행. 도메인 인증 완료 후 발급
# ──────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ──────────────────────────────────────────────────────────────
# [S7c·d] Telegram Bot — M13·M15·M19 2채널 알림
# BL-KRIT-5 선행. BotFather로 bot 생성 후 발급
# ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=xxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# comma-separated chat IDs (어드민 3인)
TELEGRAM_CHAT_IDS=123456789,234567890,345678901

# ──────────────────────────────────────────────────────────────
# [S7c] 한국투자증권 OpenAPI — 장중 WebSocket 구독 (M13) 전용
# 2026-04-22 DQ-7: S8 주식 자동매매용 APP_KEY/SECRET는 per-admin DB로 이관.
# 어드민 각자 `/admin/settings/brokerage` UI에서 입력 (brokerage_connection 테이블에 AES-256-GCM 암호화 저장).
# 아래 블록은 필요 시 S7c WebSocket 구독용으로만 복원 (기본은 주석 유지).
# ──────────────────────────────────────────────────────────────
# KIS_APP_KEY=your_kis_app_key
# KIS_APP_SECRET=your_kis_app_secret
# KIS_ACCOUNT_NO=12345678-01
# KIS_MOCK_MODE=true

# ──────────────────────────────────────────────────────────────
# [S8 코인] 바이낸스 USDT-M 선물 — 2026-04-22 DQ-7으로 per-admin DB 저장.
# env 투입 불필요. `/admin/settings/binance` UI에서 어드민 각자 입력.
# BL-KRIT-9(IP·KYC) 검증은 S8 킥오프 시 수행.
# ──────────────────────────────────────────────────────────────
# BINANCE_API_KEY=(DQ-7 이후 per-admin DB 저장 — env 미사용)
# BINANCE_API_SECRET=(동일)
# BINANCE_TESTNET=true

# ──────────────────────────────────────────────────────────────
# [배포] Vercel Cron 인증 — DQ-7
# 랜덤 32+ 문자 시크릿 권장. /api/cron/* 핸들러에서 Authorization 헤더 검증
# 생성: openssl rand -hex 32
# ──────────────────────────────────────────────────────────────
CRON_SECRET=generate_random_secret_32_plus_chars

# ──────────────────────────────────────────────────────────────
# [DQ-7 신규 2026-04-22] Admin Credential System
# ──────────────────────────────────────────────────────────────

# Master Encryption Key — per-admin API 크레덴셜 암호화용 (AES-256-GCM, 32 bytes).
# 64자 hex. 로컬과 Vercel env 반드시 **동일 값** (다르면 복호화 실패 → credential 갈라짐).
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_CRED_MASTER_KEY=64_char_hex_generated_by_node_crypto

# 실계좌(KIS) · 메인넷(Binance) 저장 권한자 1인. 친구 2명은 모의/테스트넷만 허용.
# ADMIN_EMAILS 중 1개 이메일이어야 함.
ADMIN_REP_EMAIL=rep@example.com

# ──────────────────────────────────────────────────────────────
# [S7e T7e.8 — 2026-05-12] Tier 0 인디케이터 스크리닝 외부 데이터 소스
# DART OpenAPI: 재무 standalone/quality 기반 Signal 4·5 산출 (마이그 0013/0014 의존)
# KRX login: data.krx.co.kr — pykrx universe(코스피·코스닥) fetch
# 사용 위치: scripts/screen_shortlist_tier0.py + scripts/seed_dart_corp_codes.py
# ──────────────────────────────────────────────────────────────
DART_API_KEY=your_dart_open_api_key
KRX_ID=your_krx_login_id
KRX_PW=your_krx_password

# ──────────────────────────────────────────────────────────────
# [선택] 로컬 개발용 플래그
# ──────────────────────────────────────────────────────────────
# NEXT_PUBLIC_APP_ENV=development
