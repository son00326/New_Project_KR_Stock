{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "src/app/api/cron/monthly-batch/report-worker/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/monthly-batch/selection-worker/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/reflection-job/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/monthly-batch/report-worker",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/monthly-batch/selection-worker",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/morning-briefing",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron/news-sweep",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/silent-health",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/reflection-job",
      "schedule": "30 1 * * *"
    },
    {
      "path": "/api/cron/exit-signal",
      "schedule": "30 15 * * *"
    },
    {
      "path": "/api/cron/exit-outcome",
      "schedule": "0 16 * * *"
    }
  ]
}
